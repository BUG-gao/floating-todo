{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "悬浮待办",
  "version": "0.3.1",
  "identifier": "com.gaopengfei.floating-todo",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "悬浮待办",
        "label": "main",
        "width": 340,
        "height": 560,
        "minWidth": 220,
        "minHeight": 180,
        "maxWidth": 460,
        "maxHeight": 760,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "center": false,
        "x": 1100,
        "y": 80
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
